{
  "manifest_version": 3,
  "name": "better34",
  "version": "1.6",
  "description": "Кнопки для отправки медиа в Telegram, скачивания на ПК и удобного просмотра",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://*.rule34.xxx/*",
    "https://api.telegram.org/*"
  ],
  "action": {
    "default_icon": "icon.png",
    "default_title": "better34",
    "default_popup": "popup.html"
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://rule34.xxx/*",
        "https://*.rule34.xxx/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}